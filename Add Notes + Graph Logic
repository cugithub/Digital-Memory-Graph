const express = require("express");
const router = express.Router();
const driver = require("../db");
const { extractKeywords } = require("../services/aiService");

// Add Note API
router.post("/add-note", async (req, res) => {
  const { title, content } = req.body;

  const session = driver.session();

  try {
    // Step 1: Get keywords from AI
    const keywords = await extractKeywords(content);

    // Step 2: Create Note node
    await session.run(
      `CREATE (n:Note {title: $title, content: $content})`,
      { title, content }
    );

    // Step 3: Create Topic nodes + relationships
    for (let keyword of keywords) {
      await session.run(
        `
        MERGE (t:Topic {name: $keyword})
        WITH t
        MATCH (n:Note {title: $title})
        MERGE (n)-[:CONTAINS]->(t)
        `,
        { keyword, title }
      );
    }

    res.json({ message: "Note added with graph links!" });

  } catch (err) {
    res.status(500).json(err);
  } finally {
    await session.close();
  }
});

module.exports = router;
